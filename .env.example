# Google Gemini (profiling + extraction)
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=0.2

# Pipeline tuning
PIPELINE_GEMINI_DELAY_SECONDS=2.0
PIPELINE_GEMINI_RETRIES=3

# Optional: override output directory (default: ./output)
# PIPELINE_OUTPUT_DIR=
