# Copy to .env and fill in values. Do not commit .env.

# Quran.Foundation content API (verses, translations, tafsir, audio)
QURAN_CLIENT_ID=
QURAN_CLIENT_SECRET=

# Pre-live OAuth + user API (bookmarks, etc.)
QF_USER_CLIENT_ID=
QF_USER_CLIENT_SECRET=
QF_USER_OAUTH_BASE=https://prelive-oauth2.quran.foundation
QF_USER_API_BASE=https://apis-prelive.quran.foundation

# Production (Vercel): must match Quran Foundation registered callback
QF_USER_REDIRECT_URI=https://ayat-visualization.vercel.app/callback

# Local dev: use .env.local with http://localhost:3000/callback instead

# Session cookie encryption (openssl rand -base64 32)
SESSION_SECRET=
